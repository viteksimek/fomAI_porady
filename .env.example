# Core GCP
GOOGLE_CLOUD_PROJECT=my-project
GCS_BUCKET=my-audio-bucket
MODEL_REGION=europe-west1
# Přepis: chirp_3 (Speech v2, SPEECH_REGION us|eu) nebo vertex_gemini (audio v MODEL_REGION)
TRANSCRIPTION_PROVIDER=chirp_3
SPEECH_REGION=eu
MODEL_TRANSCRIPT=gemini-2.5-flash
MODEL_MINUTES=gemini-2.5-flash

# Job store (false = Firestore in GOOGLE_CLOUD_PROJECT)
USE_MEMORY_STORE=false

# Async processing: true = run pipeline in-process (local dev); false = Cloud Tasks
PROCESS_INLINE=true

# Cloud Tasks (production on Cloud Run)
CLOUD_RUN_SERVICE_URL=https://meeting-api-xxxxx.run.app
CLOUD_TASKS_LOCATION=europe-west1
CLOUD_TASKS_QUEUE=meeting-jobs
CLOUD_TASKS_INVOKER_SA=cloud-tasks-invoker@my-project.iam.gserviceaccount.com
SKIP_INTERNAL_OIDC=true

# Optional API key for /v1/* (Power Automate header X-API-Key)
# API_KEY=

SIGNED_URL_EXP_SECONDS=900
